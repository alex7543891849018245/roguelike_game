#:kivy 2.1.0

<SplashScreen>:
    name: 'splash'
    
    FloatLayout:
        canvas:
            Color:
                rgba: 0, 0, 0, 1
            Rectangle:
                pos: self.pos
                size: self.size
        
        BoxLayout:
            orientation: 'vertical'
            size_hint: (0.8, 0.6)
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            spacing: 20
            
            Label:
                id: logo
                text: 'AlexStudio Code'
                font_size: '50sp'
                bold: True
                color: (1, 0.84, 0, 1)
                halign: 'center'
                valign: 'middle'
                size_hint_y: 0.6