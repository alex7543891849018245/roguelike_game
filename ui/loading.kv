#:kivy 2.1.0

<LoadingScreen>:
    name: 'loading'
    
    FloatLayout:
        canvas:
            Color:
                rgba: 0.1, 0.1, 0.15, 1
            Rectangle:
                pos: self.pos
                size: self.size
        
        BoxLayout:
            orientation: 'vertical'
            size_hint: (0.8, 0.7)
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            spacing: 30
            
            Label:
                text: 'ROGUELIKE ADVENTURE'
                font_size: '40sp'
                bold: True
                color: (1, 0.84, 0, 1)
                halign: 'center'
                size_hint_y: 0.3
            
            Label:
                id: loading_text
                text: 'Загрузка...'
                font_size: '20sp'
                color: (1, 1, 1, 1)
                halign: 'center'
                size_hint_y: 0.1