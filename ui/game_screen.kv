#:kivy 2.1.0

<GameScreen>:
    name: 'game'
    
    BoxLayout:
        orientation: 'horizontal'
        
        # Левая панель с картой (70%)
        BoxLayout:
            orientation: 'vertical'
            size_hint_x: 0.7
            
            MapWidget:
                id: map_widget
                player: root.player
                game_map: root.game_map
            
            MessageLog:
                id: message_log
                size_hint_y: 0.15
        
        # Правая панель с управлением (30%)
        BoxLayout:
            id: controls_layout
            orientation: 'vertical'
            size_hint_x: 0.3
            spacing: 5
            padding: 5
            
            StatusPanel:
                id: status_panel
                size_hint_y: 0.25